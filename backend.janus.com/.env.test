# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'

# Feature tests require a real MariaDB database.
# Run via `make test-backend` (inside Docker) or set DB_* vars to point at a local DB.
# When running inside the Janus Docker stack, use the 'mariadb' service host.
DATABASE_URL="mysql://janus:janus@mariadb:3306/janus_test?serverVersion=11.4-MariaDB&charset=utf8mb4"

# JWT — symmetric HMAC-SHA256 test secret
JWT_SECRET=test-jwt-secret-for-phpunit
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# Disable messenger transports in tests
MESSENGER_TRANSPORT_DSN=in-memory://
