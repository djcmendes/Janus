# ─────────────────────────────────────────────
# Janus Platform — Environment Variables
# Copy to .env.local and fill in real values
# DO NOT commit .env.local to git
# ─────────────────────────────────────────────

# ── General ───────────────────────────────────
APP_ENV=dev

# ── Database (MariaDB) ────────────────────────
DB_ROOT_PASSWORD=rootpassword
DB_NAME=janus
DB_USER=janus
DB_PASSWORD=januspassword

# ── Cache (Redis) ─────────────────────────────
REDIS_PASSWORD=redispassword

# ── Message Broker (RabbitMQ) ─────────────────
RABBITMQ_USER=janus
RABBITMQ_PASSWORD=januspassword

# ── Symfony Backend ───────────────────────────
APP_SECRET=changethis_app_secret_32chars_min

# ── JWT Authentication ────────────────────────
JWT_SECRET=changethis_jwt_secret_must_be_32chars!
JWT_ACCESS_TTL=900       # 15 minutes in seconds
JWT_REFRESH_TTL=604800   # 7 days in seconds

# ── CORS ──────────────────────────────────────
CORS_ALLOW_ORIGIN=http://janus.com

# ── Email (optional) ──────────────────────────
MAILER_DSN=smtp://localhost:1025
